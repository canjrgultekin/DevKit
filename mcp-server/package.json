{
  "name": "devkit-mcp-server",
  "version": "1.3.1",
  "description": "DevKit MCP Server - Bridge AI code generation with real project workflows. Provides Claude Desktop integration for project scaffolding, file import, Git management, Docker Compose, Azure deployment, and credential management.",
  "author": "Can Gultekin",
  "license": "MIT",
  "type": "module",
  "bin": {
    "devkit-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "devkit",
    "mcp",
    "claude",
    "ai",
    "code-generation",
    "scaffolding",
    "developer-tools",
    "azure",
    "docker",
    "git"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/canjrgultekin/DevKit"
  },
  "homepage": "https://github.com/canjrgultekin/DevKit#readme",
  "bugs": {
    "url": "https://github.com/canjrgultekin/DevKit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
