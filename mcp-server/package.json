{
  "name": "devkit-mcp-server",
  "version": "1.3.10",
  "description": "DevKit MCP Server + Jarwis AI Companion System - 160+ tools for full-stack development via Claude Desktop. Includes persistent memory, connector orchestration (Playwright, Windows-MCP, Excel-MCP), project scaffolding, architecture design, Git, Docker, Azure deploy, DB operations (PostgreSQL/MSSQL/Couchbase), Redis, Kafka, build/test/publish, shell execution, file management, code generation, and more.",
  "author": "Can Gultekin",
  "license": "MIT",
  "type": "module",
  "bin": {
    "devkit-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/**/*",
    "prompts/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "devkit",
    "mcp",
    "claude",
