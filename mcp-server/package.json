    "playwright",
    "browser-automation",
    "desktop-automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/canjrgultekin/DevKit"
  },
  "homepage": "https://github.com/canjrgultekin/DevKit#readme",
